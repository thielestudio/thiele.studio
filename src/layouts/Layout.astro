---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Daniel Thiele - Strategy, Direction & Design for digital-first brands",
  description = "Daniel Thiele. Strategy, Direction and Design for digital-first brands. Freelance Creative Director and Product Designer from Bochum.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="logo small">Designstudio Daniel Thiele</a>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer small">
      <div>Designstudio Daniel Thiele, {new Date().getFullYear()}</div>
      <div class="footer-links">
        <a href="mailto:post@thiele.studio">post@thiele.studio</a>
        <a href="https://www.linkedin.com/in/danielthiele/" target="_blank" rel="noopener">LinkedIn</a>
        <a href="/legal">Impressum</a>
      </div>
    </footer>

    <div class="scroll-blur" aria-hidden="true">
      <div class="scroll-blur__layer" data-l="1"></div>
      <div class="scroll-blur__layer" data-l="2"></div>
      <div class="scroll-blur__layer" data-l="3"></div>
    </div>

    <div class="cursor" aria-hidden="true"><span class="cursor__label">view</span></div>

    <script>
      import Lenis from "lenis";

      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
      });

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      const parallaxItems = Array.from(
        document.querySelectorAll<HTMLElement>("[data-speed]")
      );

      function updateParallax() {
        const vh = window.innerHeight;
        for (const el of parallaxItems) {
          const speed = parseFloat(el.dataset.speed || "1");
          const rect = el.getBoundingClientRect();
          const itemCenter = rect.top + rect.height / 2;
          const relative = (itemCenter - vh / 2) / vh;
          const offset = relative * (1 - speed) * 260;
          el.style.transform = `translate3d(0, ${offset.toFixed(2)}px, 0)`;
        }
      }

      lenis.on("scroll", updateParallax);
      updateParallax();
      window.addEventListener("resize", updateParallax);

      // Scroll-velocity driven blur zone at the bottom edge.
      // Faster scroll → taller blur. Comes to rest → eases back down.
      const blur = document.querySelector<HTMLElement>(".scroll-blur");
      const reduceMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      if (blur && !reduceMotion) {
        const MIN_H = 90; // resting height in px
        const MAX_H = 300; // peak height at high velocity
        const SENSITIVITY = 9; // px of height per unit of velocity
        const FADE_ZONE = 260; // px before the bottom where the blur fades out
        let target = MIN_H;
        let current = MIN_H;
        let opacity = 1;

        lenis.on("scroll", ({ velocity }: { velocity: number }) => {
          const v = Math.abs(velocity);
          target = Math.min(MAX_H, MIN_H + v * SENSITIVITY);
        });

        function tick() {
          // target decays back toward the resting height
          target += (MIN_H - target) * 0.06;
          // current chases target smoothly
          current += (target - current) * 0.14;
          blur.style.setProperty("--blur-h", current.toFixed(1) + "px");

          // fade out near the bottom so the footer stays legible
          const distanceToEnd = lenis.limit - lenis.scroll;
          const targetOpacity = Math.max(0, Math.min(1, distanceToEnd / FADE_ZONE));
          opacity += (targetOpacity - opacity) * 0.14;
          blur.style.opacity = opacity.toFixed(3);

          requestAnimationFrame(tick);
        }
        blur.style.setProperty("--blur-h", MIN_H + "px");
        requestAnimationFrame(tick);
      }

      // Custom cursor: trailing circle that grows over interactive elements.
      const cursor = document.querySelector<HTMLElement>(".cursor");
      const finePointer = window.matchMedia("(pointer: fine)").matches;

      if (cursor && finePointer) {
        document.documentElement.classList.add("has-cursor");

        // GROW: anything interactive makes the cursor expand.
        // VIEW: only project-like targets also show the "view" label.
        const GROW_SELECTOR = 'a, button, .item, .next-project, [data-cursor]';
        const VIEW_SELECTOR = '.item, .next-project, [data-cursor="view"]';
        let mouseX = window.innerWidth / 2;
        let mouseY = window.innerHeight / 2;
        let curX = mouseX;
        let curY = mouseY;
        let seen = false;

        window.addEventListener("mousemove", (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
          if (!seen) {
            seen = true;
            cursor.classList.add("is-visible");
          }
        });

        // hide when the pointer leaves the window, show again on re-entry
        document.addEventListener("mouseleave", () =>
          cursor.classList.remove("is-visible")
        );
        document.addEventListener("mouseenter", () =>
          cursor.classList.add("is-visible")
        );

        // delegate hover growth for any interactive target,
        // and the "view" label for project-like targets
        document.addEventListener("mouseover", (e) => {
          const t = e.target as HTMLElement;
          if (t.closest(GROW_SELECTOR)) cursor.classList.add("is-hover");
          if (t.closest(VIEW_SELECTOR)) cursor.classList.add("is-view");
        });
        document.addEventListener("mouseout", (e) => {
          const t = e.target as HTMLElement;
          if (t.closest(GROW_SELECTOR)) cursor.classList.remove("is-hover");
          if (t.closest(VIEW_SELECTOR)) cursor.classList.remove("is-view");
        });

        function cursorTick() {
          curX += (mouseX - curX) * 0.2;
          curY += (mouseY - curY) * 0.2;
          cursor.style.left = curX.toFixed(2) + "px";
          cursor.style.top = curY.toFixed(2) + "px";
          requestAnimationFrame(cursorTick);
        }
        requestAnimationFrame(cursorTick);
      }

      // Text scramble on hover: letters flicker through random glyphs
      // and settle back into the word. Refined, quick, letter-based.
      const GLYPHS = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789#%*/·";

      function scramble(el: HTMLElement) {
        const original = el.dataset.text ?? el.textContent ?? "";
        el.dataset.text = original;
        const len = original.length;
        let frame = 0;
        const total = Math.min(26, len + 12);
        const timer = window.setInterval(() => {
          frame++;
          let out = "";
          for (let i = 0; i < len; i++) {
            const ch = original[i];
            // reveal left-to-right; keep spaces and punctuation stable
            const revealAt = (i / len) * total * 0.7;
            if (ch === " " || ch === "@" || ch === "." || frame >= revealAt) {
              out += ch;
            } else {
              out += GLYPHS[(Math.random() * GLYPHS.length) | 0];
            }
          }
          el.textContent = out;
          if (frame >= total) {
            window.clearInterval(timer);
            el.textContent = original;
          }
        }, 28);
        el.dataset.timer = String(timer);
      }

      const scrambleEls = document.querySelectorAll<HTMLElement>(
        '[data-scramble], .logo, .footer-links a, .next-title'
      );
      scrambleEls.forEach((el) => {
        el.dataset.text = (el.textContent ?? "").trim();
        el.addEventListener("mouseenter", () => {
          const prev = Number(el.dataset.timer);
          if (prev) window.clearInterval(prev);
          scramble(el);
        });
      });
    </script>

    <style>
      .site-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 10;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: var(--pad);
      }

      .logo {
        font-weight: 500;
      }

      .site-nav {
        display: flex;
        gap: 24px;
        font-weight: 500;
      }

      .site-footer {
        padding: var(--pad);
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid rgba(0, 0, 0, 0.1);
      }

      .footer-links {
        display: flex;
        gap: 24px;
      }

      @media (max-width: 768px) {
        .site-footer {
          flex-direction: column;
          gap: 16px;
          align-items: flex-start;
        }
      }

      /*
        Progressive blur zone pinned to the bottom edge.
        Three stacked layers with increasing blur, each masked so the
        blur ramps up toward the bottom (gaussian-style falloff).
        Height is driven by --blur-h, set from scroll velocity in JS.
      */
      .scroll-blur {
        position: fixed;
        left: 0;
        right: 0;
        bottom: 0;
        height: var(--blur-h, 90px);
        z-index: 20;
        pointer-events: none;
        /* own compositing context so backdrop-filter keeps rendering
           even though the custom cursor uses mix-blend-mode */
        isolation: isolate;
      }

      .scroll-blur__layer {
        position: absolute;
        inset: 0;
      }

      .scroll-blur__layer[data-l="1"] {
        backdrop-filter: blur(2px);
        -webkit-backdrop-filter: blur(2px);
        -webkit-mask-image: linear-gradient(
          to top,
          rgba(0, 0, 0, 1) 0%,
          rgba(0, 0, 0, 1) 40%,
          rgba(0, 0, 0, 0) 100%
        );
        mask-image: linear-gradient(
          to top,
          rgba(0, 0, 0, 1) 0%,
          rgba(0, 0, 0, 1) 40%,
          rgba(0, 0, 0, 0) 100%
        );
      }

      .scroll-blur__layer[data-l="2"] {
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        -webkit-mask-image: linear-gradient(
          to top,
          rgba(0, 0, 0, 1) 0%,
          rgba(0, 0, 0, 1) 18%,
          rgba(0, 0, 0, 0) 62%
        );
        mask-image: linear-gradient(
          to top,
          rgba(0, 0, 0, 1) 0%,
          rgba(0, 0, 0, 1) 18%,
          rgba(0, 0, 0, 0) 62%
        );
      }

      .scroll-blur__layer[data-l="3"] {
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        -webkit-mask-image: linear-gradient(
          to top,
          rgba(0, 0, 0, 1) 0%,
          rgba(0, 0, 0, 0) 32%
        );
        mask-image: linear-gradient(
          to top,
          rgba(0, 0, 0, 1) 0%,
          rgba(0, 0, 0, 0) 32%
        );
      }

      @media (prefers-reduced-motion: reduce) {
        .scroll-blur {
          height: 90px;
        }
      }

      /*
        Custom cursor: a small circle that trails the mouse with a light
        lerp, inverted against everything via mix-blend-mode so it stays
        visible over cream, ink and imagery alike. Grows over anything
        interactive. Only active for a real (fine) pointer.
      */
      /*
        No mix-blend-mode here on purpose: it silently disables the
        backdrop-filter blur zone in Chromium. Instead the cursor flips
        colour to stay visible on both grounds — dark dot on the cream
        page, light block with dark label over the (dark) project images.
      */
      .cursor {
        position: fixed;
        top: 0;
        left: 0;
        width: 16px;
        height: 16px;
        border-radius: 5px;
        background: var(--color-fg);
        pointer-events: none;
        z-index: 9999;
        opacity: 0;
        transform: translate3d(-50%, -50%, 0);
        display: flex;
        align-items: center;
        justify-content: center;
        transition:
          width 300ms cubic-bezier(0.2, 0.8, 0.2, 1),
          height 300ms cubic-bezier(0.2, 0.8, 0.2, 1),
          border-radius 300ms cubic-bezier(0.2, 0.8, 0.2, 1),
          background 300ms ease,
          opacity 300ms ease;
        will-change: transform, width, height;
      }

      .cursor__label {
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--color-fg);
        opacity: 0;
        transition: opacity 200ms ease;
        pointer-events: none;
      }

      html.has-cursor .cursor.is-visible {
        opacity: 1;
      }

      html.has-cursor .cursor.is-hover {
        width: 74px;
        height: 74px;
        border-radius: 16px;
        background: var(--color-bg);
      }

      html.has-cursor .cursor.is-view .cursor__label {
        opacity: 1;
        transition: opacity 200ms ease 80ms;
      }

      /* hide the native pointer only when the custom one is active */
      html.has-cursor,
      html.has-cursor a,
      html.has-cursor button {
        cursor: none;
      }
    </style>
  </body>
</html>
