---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Daniel Thiele - Strategy, Direction & Design for digital-first brands",
  description = "Daniel Thiele. Strategy, Direction and Design for digital-first brands. Freelance Creative Director and Product Designer from Bochum.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="logo small">Designstudio Daniel Thiele</a>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer small">
      <div>Designstudio Daniel Thiele, {new Date().getFullYear()}</div>
      <div class="footer-links">
        <a href="mailto:post@thiele.studio">post@thiele.studio</a>
        <a href="https://www.linkedin.com/in/danielthiele/" target="_blank" rel="noopener">LinkedIn</a>
        <a href="/legal">Impressum</a>
      </div>
    </footer>

    <div class="scroll-blur" aria-hidden="true">
      <div class="scroll-blur__layer" data-l="1"></div>
      <div class="scroll-blur__layer" data-l="2"></div>
      <div class="scroll-blur__layer" data-l="3"></div>
    </div>

    <script>
      import Lenis from "lenis";

      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
      });

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      const parallaxItems = Array.from(
        document.querySelectorAll<HTMLElement>("[data-speed]")
      );

      function updateParallax() {
        const vh = window.innerHeight;
        for (const el of parallaxItems) {
          const speed = parseFloat(el.dataset.speed || "1");
          const rect = el.getBoundingClientRect();
          const itemCenter = rect.top + rect.height / 2;
          const relative = (itemCenter - vh / 2) / vh;
          const offset = relative * (1 - speed) * 260;
          el.style.transform = `translate3d(0, ${offset.toFixed(2)}px, 0)`;
        }
      }

      lenis.on("scroll", updateParallax);
      updateParallax();
      window.addEventListener("resize", updateParallax);

      // Scroll-velocity driven blur zone at the bottom edge.
      // Faster scroll → taller blur. Comes to rest → eases back down.
      const blur = document.querySelector<HTMLElement>(".scroll-blur");
      const reduceMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      if (blur && !reduceMotion) {
        const MIN_H = 90; // resting height in px
        const MAX_H = 300; // peak height at high velocity
        const SENSITIVITY = 9; // px of height per unit of velocity
        let target = MIN_H;
        let current = MIN_H;

        lenis.on("scroll", ({ velocity }: { velocity: number }) => {
          const v = Math.abs(velocity);
          target = Math.min(MAX_H, MIN_H + v * SENSITIVITY);
        });

        function tick() {
          // target decays back toward the resting height
          target += (MIN_H - target) * 0.06;
          // current chases target smoothly
          current += (target - current) * 0.14;
          blur.style.setProperty("--blur-h", current.toFixed(1) + "px");
          requestAnimationFrame(tick);
        }
        blur.style.setProperty("--blur-h", MIN_H + "px");
        requestAnimationFrame(tick);
      }
    </script>

    <style>
      .site-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 10;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: var(--pad);
      }

      .logo {
        font-weight: 500;
      }

      .site-nav {
        display: flex;
        gap: 24px;
        font-weight: 500;
      }

      .site-footer {
        padding: var(--pad);
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid rgba(0, 0, 0, 0.1);
      }

      .footer-links {
        display: flex;
        gap: 24px;
      }

      @media (max-width: 768px) {
        .site-footer {
          flex-direction: column;
          gap: 16px;
          align-items: flex-start;
        }
      }

      /*
        Progressive blur zone pinned to the bottom edge.
        Three stacked layers with increasing blur, each masked so the
        blur ramps up toward the bottom (gaussian-style falloff).
        Height is driven by --blur-h, set from scroll velocity in JS.
      */
      .scroll-blur {
        position: fixed;
        left: 0;
        right: 0;
        bottom: 0;
        height: var(--blur-h, 90px);
        z-index: 20;
        pointer-events: none;
      }

      .scroll-blur__layer {
        position: absolute;
        inset: 0;
      }

      .scroll-blur__layer[data-l="1"] {
        backdrop-filter: blur(2px);
        -webkit-backdrop-filter: blur(2px);
        -webkit-mask-image: linear-gradient(
          to top,
          rgba(0, 0, 0, 1) 0%,
          rgba(0, 0, 0, 1) 40%,
          rgba(0, 0, 0, 0) 100%
        );
        mask-image: linear-gradient(
          to top,
          rgba(0, 0, 0, 1) 0%,
          rgba(0, 0, 0, 1) 40%,
          rgba(0, 0, 0, 0) 100%
        );
      }

      .scroll-blur__layer[data-l="2"] {
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        -webkit-mask-image: linear-gradient(
          to top,
          rgba(0, 0, 0, 1) 0%,
          rgba(0, 0, 0, 1) 18%,
          rgba(0, 0, 0, 0) 62%
        );
        mask-image: linear-gradient(
          to top,
          rgba(0, 0, 0, 1) 0%,
          rgba(0, 0, 0, 1) 18%,
          rgba(0, 0, 0, 0) 62%
        );
      }

      .scroll-blur__layer[data-l="3"] {
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        -webkit-mask-image: linear-gradient(
          to top,
          rgba(0, 0, 0, 1) 0%,
          rgba(0, 0, 0, 0) 32%
        );
        mask-image: linear-gradient(
          to top,
          rgba(0, 0, 0, 1) 0%,
          rgba(0, 0, 0, 0) 32%
        );
      }

      @media (prefers-reduced-motion: reduce) {
        .scroll-blur {
          height: 90px;
        }
      }
    </style>
  </body>
</html>
