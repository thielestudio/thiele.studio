---
import Layout from "../layouts/Layout.astro";

const cases = [
  {
    slug: "campany",
    title: "Campany Vans",
    cover: "/images/cases/campany/campany-01.png",
  },
  {
    slug: "qruise",
    title: "Qruise",
    cover: "/images/cases/qruise/qruise-00.jpg",
  },
  {
    slug: "wikinger",
    title: "Wikinger Reisen",
    cover: "/images/cases/wikinger/wikinger-case-01.png",
  },
  {
    slug: "anny-herbs",
    title: "Anny Herbs",
    cover: "/images/cases/anny-herbs/mockup-flasche-hand.png",
  },
  {
    slug: "slow-supply",
    title: "Slow Supply",
    cover: "/images/cases/slow-supply/slowsupply-branding-00.jpg",
  },
  {
    slug: "wyldaway",
    title: "Wyldaway",
    cover: "/images/cases/wyldaway/wyldaway-00.jpg",
  },
];
---

<Layout>
  <section class="hero" id="work">
    <div class="hero-intro">
      <h1>Design that makes a difference in a way that makes sense.</h1>
    </div>

    <div class="case-grid">
      {
        cases.map((c, i) => {
          const speeds = [0.85, 1.18, 0.92, 1.12, 0.88, 1.15];
          return (
            <a
              href={`/projects/${c.slug}`}
              class={`item item-${i + 1}`}
              aria-label={c.title}
              data-speed={speeds[i]}
            >
              <img src={c.cover} alt={c.title} loading="eager" />
            </a>
          );
        })
      }
    </div>
  </section>

  <section class="claim" id="about">
    <h2 class="claim-headline">Driving growth through clarity.</h2>
    <p class="claim-body">
      I support startups and venture studios through strategic advisory,
      scalable brand foundations and design systems that reduce noise,
      raise trust and elevate sustainable growth.
    </p>
  </section>

</Layout>

<style>
  .hero {
    padding: calc(var(--pad) * 3) var(--pad) var(--pad);
  }

  .hero-intro {
    max-width: 1400px;
    margin: 0 auto calc(var(--pad) * 2);
  }

  .hero-intro h1 {
    font-weight: 500;
    letter-spacing: -0.03em;
    max-width: 18ch;
  }

  /*
    Case Grid: 12-col Editorial Rhythm
    Sequenz (span / start) für 6 Items:
      1: 7 / 1   links groß
      2: 4 / 9   rechts klein
      3: 5 / 2   mitte-links, Pair-Hälfte 1
      4: 3 / 8   mitte-rechts, Pair-Hälfte 2
      5: 5 / 1   links mittel
      6: 6 / 7   rechts groß
    Pair: Item 3 + 4 teilen sich grid-row 3.
    Bei mehr als 6 Items: Sequenz wiederholt sich, oder neue Stufen ergänzen.
  */
  .case-grid {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: auto;
    column-gap: var(--gap);
    row-gap: calc(var(--gap) * 2);
    align-items: start;
  }

  .item {
    display: block;
    overflow: hidden;
  }

  .item img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .item:hover img {
    transform: scale(1.02);
  }

  .item-1 { grid-column: 1 / span 7;  grid-row: 1; }
  .item-2 { grid-column: 9 / span 4;  grid-row: 1; margin-top: calc(var(--gap) * 2); }
  .item-3 { grid-column: 2 / span 5;  grid-row: 2; margin-top: calc(var(--gap) * 3); }
  .item-4 { grid-column: 8 / span 5;  grid-row: 2; }
  .item-5 { grid-column: 1 / span 7;  grid-row: 3; }
  .item-6 { grid-column: 9 / span 4;  grid-row: 3; margin-top: calc(var(--gap) * 2); }

  .claim {
    padding: calc(var(--pad) * 4) var(--pad);
    max-width: 1400px;
    margin: 0 auto;
  }

  .claim-headline {
    font-size: var(--fs-h1);
    line-height: var(--lh-h1);
    font-weight: 500;
    letter-spacing: -0.02em;
    margin-bottom: var(--gap);
  }

  .claim-body {
    font-size: var(--fs-h2);
    line-height: 1.15;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .label {
    color: var(--color-muted);
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: calc(var(--pad) * 4);
    }

    .hero-intro {
      flex-direction: column;
      align-items: flex-start;
      margin-bottom: var(--gap);
    }

    .case-grid {
      display: flex;
      flex-direction: column;
      gap: var(--gap);
    }

    .item-1,
    .item-2,
    .item-3,
    .item-4,
    .item-5,
    .item-6 {
      grid-column: auto;
      grid-row: auto;
      width: 100%;
    }

    .claim {
      padding: calc(var(--pad) * 2) var(--pad);
    }

    .claim-headline {
      font-size: 48px;
    }

    .claim-body {
      font-size: 28px;
      line-height: 1.2;
    }
  }
</style>
